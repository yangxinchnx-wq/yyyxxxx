# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SOLOFORGE_BACKEND_URL: Optional override for the SoloForge backend (port 3001).
# The UI's server.ts proxies all /api/* business endpoints here.
# Defaults to http://localhost:3001 if unset.
# SOLOFORGE_BACKEND_URL="http://localhost:3001"
